<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Header ──────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Détails de l'incident"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/color_primary"
            android:layout_marginBottom="20dp"/>

        <!-- ── Issue card ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <!-- ID row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Référence"
                    android:textSize="12sp"
                    android:textColor="@color/color_on_surface_variant"/>

                <TextView
                    android:id="@+id/tv_issue_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary"/>
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tv_issue_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_primary"
                android:layout_marginBottom="8dp"/>

            <!-- Description -->
            <TextView
                android:id="@+id/tv_issue_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/color_on_surface_variant"
                android:layout_marginBottom="16dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_outline_variant"
                android:layout_marginBottom="16dp"/>

            <!-- Priority row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Priorité"
                    android:textSize="13sp"
                    android:textColor="@color/color_on_surface_variant"/>

                <TextView
                    android:id="@+id/tv_issue_priority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_tertiary"/>
            </LinearLayout>

            <!-- Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Statut"
                    android:textSize="13sp"
                    android:textColor="@color/color_on_surface_variant"/>

                <TextView
                    android:id="@+id/tv_issue_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_secondary"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Safety Protocol card ───────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ Protocole de sécurité"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/color_tertiary"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tv_safety_protocol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/color_primary"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
